<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarTop"
        style="@style/tnSwitch"
        android:layout_width="match_parent"
        android:layout_height="@dimen/downToolbar"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/library"
        app:titleMarginStart="12dp"
        app:titleTextAppearance="@style/ToolbarTitleAppearance"
        app:navigationIconTint="@color/ColorChange"
        app:titleTextColor="@color/ColorChange" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabTextColor="@color/ColorChange"
        app:tabSelectedTextColor="@color/ColorChange"
        app:tabIndicatorColor="@color/ColorChange"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TabTextAppearance"
        android:background="?attr/background" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>